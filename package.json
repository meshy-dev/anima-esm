{
  "name": "anima-esm",
  "version": "0.2.0",
  "description": "Immediate-mode 3D animation framework: vanilla core (createFigure) + optional React wrapper, with WebM/WebP export",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/anima.min.mjs",
  "module": "./dist/anima.min.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/anima.min.mjs"
    },
    "./react": {
      "types": "./dist/react-index.d.ts",
      "import": "./dist/anima-react.min.mjs"
    },
    "./muxers": {
      "types": "./dist/muxers.d.ts",
      "import": "./dist/anima-muxers.min.mjs"
    },
    "./anima.min.mjs": "./dist/anima.min.mjs",
    "./anima.debug.mjs": "./dist/anima.debug.mjs",
    "./anima-react.min.mjs": "./dist/anima-react.min.mjs",
    "./anima-react.debug.mjs": "./dist/anima-react.debug.mjs",
    "./anima-muxers.min.mjs": "./dist/anima-muxers.min.mjs",
    "./anima-muxers.debug.mjs": "./dist/anima-muxers.debug.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.json",
    "ci": "node build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "three": ">=0.160"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "typescript": "^6.0.3"
  },
  "engines": { "node": ">=20" }
}
