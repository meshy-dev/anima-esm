{
  "name": "anima-esm",
  "version": "0.2.0",
  "description": "Immediate-mode 3D animation framework: vanilla core (createFigure) + optional React wrapper, with WebM/WebP export",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/anima.min.mjs",
  "module": "./dist/anima.min.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/anima.min.mjs"
    },
    "./react": {
      "types": "./dist/react-index.d.ts",
      "import": "./dist/anima-react.min.mjs"
    },
    "./anima.min.mjs": "./dist/anima.min.mjs",
    "./anima.debug.mjs": "./dist/anima.debug.mjs",
    "./anima-react.min.mjs": "./dist/anima-react.min.mjs",
    "./anima-react.debug.mjs": "./dist/anima-react.debug.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.json",
    "ci": "node build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "three": ">=0.160"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.160.0",
    "esbuild": "^0.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.0",
    "typescript": "^5.5.0"
  },
  "engines": { "node": ">=18" }
}
